# Finsio Environment Configuration
# Copy to .env and fill in your values

DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

FUSIO_SECRET=change-me-fusio-secret-min-32-chars
FUSIO_URL=http://localhost:8080

BACKEND_INTERNAL_TOKEN=change-me-internal-token

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=

POSTGRES_PASSWORD=
MYSQL_FUSIO_PASSWORD=
MYSQL_ROOT_PASSWORD=
REDIS_PASSWORD=

SENTRY_DSN=

BEANCOUNT_PATH=/app/beancount
