; ═══════════════════════════════
;  Beancount Processing Options
; ═══════════════════════════════

; Date format
option "date_format" "%Y-%m-%d"

; Decimal separator
option "decimal_separator" "."

; Rounding tolerance for balanced entries
option "experiment_rounding_tolerance" "0.005"

; Display commas in amounts (1,000.00)
option "render_commas" "TRUE"

; Transaction balancing
option "experiment_contra_income" "FALSE"
