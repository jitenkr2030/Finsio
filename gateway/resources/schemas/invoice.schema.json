{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finsio.local/schemas/invoice.json",
  "title": "Invoice",
  "description": "Schema for invoice creation and response",
  "type": "object",
  "required": ["customer_id", "customer_email", "customer_name", "line_items"],
  "properties": {
    "customer_id": {
      "type": "string",
      "description": "Unique customer identifier"
    },
    "customer_email": {
      "type": "string",
      "format": "email"
    },
    "customer_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price"],
        "properties": {
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "quantity": {
            "type": "number",
            "minimum": 0.01
          },
          "unit_price": {
            "type": "number",
            "minimum": 0
          },
          "tax_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0,
            "description": "Tax rate as decimal (e.g. 0.08 for 8%)"
          },
          "category": {
            "type": "string",
            "default": "General"
          }
        }
      }
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "default": "USD"
    },
    "due_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365,
      "default": 30
    },
    "auto_collect": {
      "type": "boolean",
      "default": false,
      "description": "Automatically generate payment link"
    },
    "processor": {
      "type": "string",
      "enum": ["stripe", "paypal", "braintree", "authorize_net"]
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    }
  }
}
